APP_ENV=production
ENABLE_API_DOCS=false
ENABLE_SEMANTIC_SEARCH=false
CORS_ALLOW_ORIGINS=https://your-netlify-site.netlify.app
ALLOWED_HOSTS=your-backend-host.example.com
ADMIN_API_KEY=replace_with_a_long_random_secret
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=60
STATE_BENCHMARK_YEARS=2024,2023,2022

GROQ_API_KEY=your_groq_key_here
CENSUS_API_KEY=your_census_key_here
BLS_API_KEY=your_bls_key_here
FRED_API_KEY=your_fred_key_here
BEA_API_KEY=your_bea_key_here
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_service_or_anon_key
